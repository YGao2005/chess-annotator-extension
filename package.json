{
  "name": "chess-annotation-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "pipeline": "tsx pipeline/src/cli.ts",
    "pipeline:run": "tsx pipeline/src/cli.ts run",
    "pipeline:metrics": "tsx pipeline/src/cli.ts metrics",
    "pipeline:mistakes": "tsx pipeline/src/cli.ts mistakes",
    "pipeline:weekly": "tsx pipeline/src/cli.ts weekly",
    "pipeline:openings": "tsx pipeline/src/cli.ts openings",
    "pipeline:bible": "tsx pipeline/src/cli.ts bible"
  },
  "description": "Chrome extension for chess.com game annotation and analysis",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "dexie": "^4.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  }
}
